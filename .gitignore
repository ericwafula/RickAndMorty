# The global gitignore (~/.gitignore_global) hides .agents and .claude. This
# repo's skills live in .agents, so re-include it here (a repo .gitignore
# outranks the global one). .claude/skills stays generated — see sync-skills.sh.
!.agents/
/.claude/skills/

